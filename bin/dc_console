#!/usr/bin/env bash
# =============================================================================
# bin/dc_console — Launch the Hasura Console
#
# Starts the console container and opens the Hasura web UI.
# Run this after bin/dc_prep has completed successfully.
#
# Usage:
#   ./bin/dc_console
# =============================================================================
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"

cd "${ROOT_DIR}"
exec docker compose up console --build
